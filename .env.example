# Copy this file to .env and fill in any overrides.
# Values here take precedence over config/settings.yaml.
# .env is gitignored — never commit secrets.

# Override the Ollama server URL (e.g. if running on a different machine)
# OLLAMA_BASE_URL=http://localhost:11434

# Override the model name
# MODEL_NAME=medgemma1.5:4b

# Select the configured model preset
# MODEL_PRESET=medgemma-4b

# Override the backend
# MODEL_BACKEND=ollama
# BACKEND=ollama

# Path to a local .gguf model file (only needed for llama_cpp backend)
# MODEL_PATH=/path/to/your/model.gguf

# Hugging Face Hub GGUF model settings (llama_cpp backend)
# LLAMA_CPP_MODEL_REPO_ID=unsloth/medgemma-1.5-4b-it-GGUF
# LLAMA_CPP_MODEL_FILENAME=medgemma-1.5-4b-it-Q4_K_M.gguf
# LLAMA_CPP_N_GPU_LAYERS=-1
# LLAMA_CPP_N_BATCH=2048
# LLAMA_CPP_N_UBATCH=1024
# LLAMA_CPP_FLASH_ATTN=1
# LLAMA_CPP_OP_OFFLOAD=1
# LLAMA_CPP_SWA_FULL=0

# Hidden generation defaults
# MODEL_CONTEXT_LENGTH=8192
# MODEL_MAX_NEW_TOKENS=256
# MODEL_TEMPERATURE=0.3

# Deployment copy mode: local, huggingface, or hosted
# APP_DEPLOYMENT=local

# UI mode: default Server UI, or "blocks" for the fallback Gradio Blocks interface
# APP_UI_MODE=blocks

# OpenAI-compatible hosted endpoint settings, e.g. Nebius Serverless AI
# OPENAI_COMPATIBLE_BASE_URL=https://your-openai-compatible-endpoint
# OPENAI_COMPATIBLE_API_KEY=your-api-key
