# Copy this file to .env and fill in any overrides.
# Values here take precedence over config/settings.yaml.
# .env is gitignored — never commit secrets.

# Override the Ollama server URL (e.g. if running on a different machine)
# OLLAMA_BASE_URL=http://localhost:11434

# Override the model name
# MODEL_NAME=medgemma

# Override the backend
# BACKEND=ollama

# Path to a local .gguf model file (only needed for llama_cpp backend)
# MODEL_PATH=/path/to/your/model.gguf
